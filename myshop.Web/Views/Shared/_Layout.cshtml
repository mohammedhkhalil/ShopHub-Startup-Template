<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - myshop.Web</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/myshop.Web.styles.css" asp-append-version="true" />

    <style>
        body {
            background: linear-gradient(135deg,#eef2f7 0%,#d9e4f5 40%,#c3dafe 100%);
            margin: 0;
            animation: fadeIn .8s ease;
        }

        @@keyframes fadeIn {
            from {
                opacity: 0;
            }

            to {
                opacity: 1;
            }
        }

        nav.navbar {
            background: linear-gradient(90deg,#ffffff,#f8fbff) !important;
            box-shadow: 0 6px 18px rgba(0,0,0,.08);
            padding: 1rem 0;
            animation: slideDown .8s ease;
        }

        @@keyframes slideDown {
            from {
                transform: translateY(-35px);
                opacity: 0;
            }

            to {
                transform: translateY(0);
                opacity: 1;
            }
        }

        .nav-link-box {
            background: linear-gradient(135deg,#00c6ff,#0072ff);
            color: white !important;
            padding: .65rem 1.25rem;
            margin-left: .75rem;
            border-radius: 14px;
            text-decoration: none;
            font-weight: 600;
            transition: .3s;
            box-shadow: 0 4px 12px rgba(0,0,0,.15);
        }

            .nav-link-box:hover {
                transform: translateY(-3px);
                background: linear-gradient(135deg,#005bea,#00c6fb);
                box-shadow: 0 8px 18px rgba(0,0,0,.2);
            }

        .home-box {
            font-size: 1.05rem;
            padding: .9rem 1.6rem;
        }

        footer {
            background: linear-gradient(90deg,#111,#1b1b1b);
            color: white;
            padding: 1.2rem 0;
            border-top-left-radius: 18px;
            border-top-right-radius: 18px;
        }

            footer a {
                color: white;
                text-decoration: none;
            }

                footer a:hover {
                    text-decoration: underline;
                }
    </style>
</head>

<body class="d-flex flex-column min-vh-100">

    <header>
        <nav class="navbar navbar-expand-sm navbar-light border-bottom">
            <div class="container">

                <a class="navbar-brand nav-link-box home-box"
                   asp-controller="Product"
                   asp-action="Index">
                    myshop.Web
                </a>

                <button class="navbar-toggler"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#navbarContent">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarContent">

                    <ul class="navbar-nav ms-auto">

                        <li class="nav-item">
                            <a class="nav-link nav-link-box"
                               asp-controller="Product"
                               asp-action="Index">
                                Products
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link nav-link-box"
                               asp-controller="Category"
                               asp-action="Index">
                                Categories
                            </a>
                        </li>

                    </ul>
                    <partial name="_LoginPartial" />
                </div>

            </div>
        </nav>
    </header>

    <main class="container flex-grow-1 py-4">
        @RenderBody()
    </main>

    <footer class="mt-auto">
        <div class="container text-center">
            &copy; @DateTime.Now.Year - myshop.Web
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>